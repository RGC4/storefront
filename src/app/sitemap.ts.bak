import { MetadataRoute } from "next";

export default function sitemap(): MetadataRoute.Sitemap {
  return [
    { url: "https://prestigeapparelgroup.com", lastModified: new Date() },
    { url: "https://prestigeapparelgroup.com/collections", lastModified: new Date() },
    { url: "https://prestigeapparelgroup.com/contact", lastModified: new Date() },
  ];
}
